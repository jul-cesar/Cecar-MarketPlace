# Environment: production or development
NODE_ENV=production

# Identity Service
BETTER_AUTH_SECRET=your-super-secret-key-change-this
BETTER_AUTH_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com
IDENTITY_DATABASE_URL=postgresql://user:password@host:5432/identity_db
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Catalog Service
CATALOG_DATABASE_URL=jdbc:postgresql://host:5432/catalog_db
CATALOG_DATABASE_USERNAME=your_db_username
CATALOG_DATABASE_PASSWORD=your_db_password

# Media Service
UPLOADTHING_TOKEN=your-uploadthing-token

# Messaging Service
MESSAGING_DATABASE_URL=postgresql://user:password@host:5432/messaging_db

# Admin Service (same DB as Identity, JDBC format)
IDENTITY_DATABASE_URL_JDBC=jdbc:postgresql://host:5432/identity_db
IDENTITY_DATABASE_USERNAME=your_db_username
IDENTITY_DATABASE_PASSWORD=your_db_password

# Frontend
VITE_GATEWAY_BASE_URL=https://yourdomain.com
VITE_MESSAGING_BASE_URL=https://yourdomain.com
VITE_MESSAGING_API_PREFIX=/api/v1/messaging
VITE_MESSAGING_SOCKET_URL=https://yourdomain.com
VITE_MESSAGING_SOCKET_PATH=/socket.io
