# Environment: production or development
NODE_ENV=production

# Identity Service
BETTER_AUTH_SECRET=your-super-secret-key-change-this
BETTER_AUTH_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com
IDENTITY_DATABASE_URL=postgresql://user:password@host:5432/identity_db
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Catalog Service
CATALOG_DATABASE_URL=jdbc:postgresql://host:5432/catalog_db
CATALOG_DATABASE_USERNAME=your_db_username
CATALOG_DATABASE_PASSWORD=your_db_password

# Media Service
UPLOADTHING_TOKEN=your-uploadthing-token

# Frontend
VITE_GATEWAY_BASE_URL=https://yourdomain.com
