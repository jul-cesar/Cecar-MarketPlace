VITE_GATEWAY_BASE_URL=http://localhost:8080
VITE_MESSAGING_BASE_URL=http://localhost:8080
VITE_MESSAGING_API_PREFIX=/api/v1/messaging
VITE_MESSAGING_SOCKET_URL=http://localhost:8080
VITE_MESSAGING_SOCKET_PATH=/api/v1/messaging/socket.io

# If your local Java gateway cannot proxy Node services, test messaging directly with:
# VITE_MESSAGING_BASE_URL=http://localhost:3002
# VITE_MESSAGING_API_PREFIX=
# VITE_MESSAGING_SOCKET_URL=http://localhost:3002
# VITE_MESSAGING_SOCKET_PATH=/socket.io
# Also set ENABLE_SERVICE_CORS=true in messaging-service when using direct browser REST.
