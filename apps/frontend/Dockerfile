# Build stage
FROM node:20-alpine AS builder

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .
ARG VITE_GATEWAY_BASE_URL
ARG VITE_MESSAGING_BASE_URL
ARG VITE_MESSAGING_API_PREFIX
ARG VITE_MESSAGING_SOCKET_URL
ARG VITE_MESSAGING_SOCKET_PATH
ENV VITE_GATEWAY_BASE_URL=${VITE_GATEWAY_BASE_URL}
ENV VITE_MESSAGING_BASE_URL=${VITE_MESSAGING_BASE_URL}
ENV VITE_MESSAGING_API_PREFIX=${VITE_MESSAGING_API_PREFIX}
ENV VITE_MESSAGING_SOCKET_URL=${VITE_MESSAGING_SOCKET_URL}
ENV VITE_MESSAGING_SOCKET_PATH=${VITE_MESSAGING_SOCKET_PATH}
RUN npm run build

# Production stage
FROM nginx:alpine

COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
